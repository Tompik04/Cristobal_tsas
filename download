:root {
  --evergreen: #041F1E;
  --evergreen-soft: #0a2e2c;
  --pale-oak: #DCCAAC;
  --platinum: #E9E9ED;
  --coffee: #0F060B;

  --oak-08: rgba(220, 202, 172, 0.08);
  --oak-10: rgba(220, 202, 172, 0.10);
  --oak-20: rgba(220, 202, 172, 0.20);
  --oak-25: rgba(220, 202, 172, 0.25);
  --oak-35: rgba(220, 202, 172, 0.35);
  --oak-55: rgba(220, 202, 172, 0.55);
  --oak-60: rgba(220, 202, 172, 0.60);

  --r: 14px;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

html, body {
  background: var(--evergreen);
  color: var(--pale-oak);
  font-family: 'Cinzel', serif;
  min-height: 100vh;
}

.hidden { display: none !important; }

button { font-family: inherit; }

/* ============ LOGIN ============ */
.login-screen {
  position: fixed; inset: 0;
  background: var(--evergreen);
  display: flex; align-items: center; justify-content: center;
  z-index: 100; padding: 2rem;
}
.login-box {
  display: flex; flex-direction: column; align-items: center;
  gap: 1rem; width: 100%; max-width: 320px;
}
.login-logo { width: 80px; height: 80px; opacity: 0.9; }
.login-logo svg { width: 100%; height: 100%; }
.login-title {
  font-size: 30px; font-weight: 600; letter-spacing: 0.3em;
  text-indent: 0.3em;
}
.login-sub { font-size: 14px; color: var(--oak-60); letter-spacing: 0.1em; }
.pin-dots { display: flex; gap: 16px; margin: 0.5rem 0 1rem; }
.pin-dots span {
  width: 14px; height: 14px; border-radius: 50%;
  border: 1.5px solid var(--oak-55); transition: background 0.15s;
}
.pin-dots span.filled { background: var(--pale-oak); border-color: var(--pale-oak); }
.pin-pad {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 12px; width: 100%;
}
.pin-key {
  aspect-ratio: 1.4; border: 1px solid var(--oak-25);
  background: var(--oak-08); color: var(--pale-oak);
  border-radius: 12px; font-size: 22px; cursor: pointer;
  transition: background 0.12s, transform 0.08s;
}
.pin-key:hover { background: var(--oak-20); }
.pin-key:active { transform: scale(0.96); }
.pin-key.ghost { background: none; border: none; cursor: default; }
.login-error { color: #e8a0a0; font-size: 13px; min-height: 18px; letter-spacing: 0.05em; }

/* ============ HEADER ============ */
.app-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 1rem 2.5%; border-bottom: 1px solid var(--oak-20);
  gap: 1rem; position: sticky; top: 0; background: var(--evergreen); z-index: 20;
}
.h-home {
  background: none; border: none; color: var(--pale-oak); cursor: pointer;
  display: flex; padding: 8px; border-radius: 10px; transition: background 0.15s; flex-shrink: 0;
}
.h-home:hover { background: var(--oak-10); }
.h-home i { font-size: 26px; }
.h-nav { display: flex; gap: clamp(12px, 3vw, 40px); flex: 1; justify-content: center; flex-wrap: wrap; }
.h-nav a {
  color: var(--pale-oak); text-decoration: none; font-size: clamp(12px, 1.6vw, 16px);
  font-weight: 500; letter-spacing: 0.14em; cursor: pointer; padding: 4px 2px;
  border-bottom: 2px solid transparent; transition: border-color 0.15s;
}
.h-nav a:hover { border-bottom-color: var(--pale-oak); }
.h-nav a.current { color: var(--oak-35); cursor: default; pointer-events: none; }
.h-logo { width: 42px; height: 42px; flex-shrink: 0; }
.h-logo svg { width: 100%; height: 100%; }

/* ============ HOME ============ */
.home {
  min-height: calc(100vh - 0px);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 2rem; padding: 2rem 2.5%; overflow: hidden;
}
.home-brand {
  font-weight: 600; color: var(--pale-oak); width: 95%; text-align: center;
  line-height: 1; white-space: nowrap; position: relative; z-index: 3;
}
.home-grid-wrap { position: relative; width: 95%; }
.home-logo {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
  width: 80%; aspect-ratio: 1; opacity: 0.12; pointer-events: none; z-index: 1;
}
.home-logo svg { width: 100%; height: 100%; }
.home-grid {
  position: relative; z-index: 2; display: grid; grid-template-columns: 1fr 1fr;
  gap: 16px; width: 100%;
}
.home-btn {
  background: var(--oak-10); border: 1px solid var(--oak-35);
  border-radius: var(--r); height: 22vw; max-height: 220px; min-height: 120px;
  display: flex; align-items: center; justify-content: center; cursor: pointer;
  transition: background 0.18s, border-color 0.18s; text-decoration: none;
}
.home-btn:hover { background: var(--oak-20); border-color: var(--oak-55); }
.home-btn span {
  font-weight: 600; color: var(--pale-oak); font-size: clamp(16px, 2.5vw, 22px);
  letter-spacing: 0.18em;
}

/* ============ VENTAS (categorías) ============ */
.view-title {
  text-align: center; font-size: clamp(20px, 3.4vw, 34px); font-weight: 600;
  letter-spacing: 0.22em; padding: 1.4rem 0 1rem;
}
.cat-grid {
  display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; padding: 0.5rem 2.5% 2rem;
}
.cat {
  background: var(--oak-08); border: 1px solid var(--oak-25); border-radius: var(--r);
  aspect-ratio: 3/4; display: flex; flex-direction: column; align-items: center;
  justify-content: center; gap: 14px; cursor: pointer; padding: 1rem;
  transition: background 0.18s, border-color 0.18s, transform 0.12s;
}
.cat:hover { background: var(--oak-20); border-color: var(--oak-55); transform: translateY(-3px); }
.cat-img { width: 70%; aspect-ratio: 1; display: flex; align-items: center; justify-content: center; }
.cat-img img { width: 100%; height: 100%; object-fit: contain; opacity: 0.9; background: var(--oak-08); border-radius: 8px; }
.cat-name { font-size: clamp(15px, 2vw, 20px); font-weight: 600; letter-spacing: 0.12em; text-align: center; }

/* ============ LISTA DE PRODUCTOS ============ */
.prod-list { padding: 0 2.5% 7rem; display: flex; flex-direction: column; gap: 12px; }
.prow {
  display: grid; grid-template-columns: 200px repeat(4, 1fr) auto; gap: 14px; align-items: center;
  background: var(--oak-08); border: 1px solid var(--oak-25); border-radius: var(--r); padding: 14px 16px;
}
.pcell { display: flex; align-items: center; gap: 12px; }
.pimg { width: 54px; height: 54px; border-radius: 8px; flex-shrink: 0; background: var(--oak-10); object-fit: contain; }
.pinfo { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
.pmarca { font-size: 14px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.pcod { font-size: 11px; color: var(--oak-55); letter-spacing: 0.08em; }
.field { display: flex; flex-direction: column; gap: 4px; }
.field label { font-size: 10px; letter-spacing: 0.12em; color: var(--oak-60); text-transform: uppercase; }
.field select {
  background: rgba(4,31,30,0.6); border: 1px solid var(--oak-35); color: var(--pale-oak);
  font-family: 'Cinzel', serif; font-size: 13px; padding: 7px 8px; border-radius: 8px; cursor: pointer; width: 100%;
}
.field select:disabled { opacity: 0.35; cursor: not-allowed; }
.field select option { background: var(--evergreen); color: var(--pale-oak); }
.field input[type=datetime-local], .field input[type=date] {
  background: rgba(4,31,30,0.6); border: 1px solid var(--oak-35); color: var(--pale-oak);
  font-family: 'Cinzel', serif; font-size: 12px; padding: 6px 8px; border-radius: 8px;
}
.pacts { display: flex; gap: 8px; }
.pact {
  width: 42px; height: 42px; border-radius: 10px; border: 1px solid var(--oak-35);
  background: var(--oak-08); color: var(--pale-oak); cursor: pointer;
  display: flex; align-items: center; justify-content: center; transition: background 0.15s, border-color 0.15s;
}
.pact:hover { background: var(--oak-20); border-color: var(--oak-60); }
.pact i { font-size: 20px; }
.pact.check:hover { background: rgba(120,200,120,0.25); border-color: rgba(120,200,120,0.6); }

/* ============ CARRITO ============ */
.cart-fab {
  position: fixed; right: 24px; bottom: 24px; z-index: 30; width: 60px; height: 60px;
  border-radius: 50%; background: var(--pale-oak); color: var(--evergreen); border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center; box-shadow: 0 6px 20px rgba(0,0,0,0.4); transition: transform 0.12s;
}
.cart-fab:hover { transform: scale(1.06); }
.cart-fab i { font-size: 26px; }
.cart-badge {
  position: absolute; top: -4px; right: -4px; background: var(--evergreen); color: var(--pale-oak);
  border: 2px solid var(--pale-oak); border-radius: 50%; width: 24px; height: 24px;
  font-size: 12px; font-family: sans-serif; display: flex; align-items: center; justify-content: center;
}

/* ============ MODAL / POPUP ============ */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.55); z-index: 40;
  display: flex; align-items: center; justify-content: center; padding: 1.5rem;
}
.modal {
  background: var(--evergreen-soft); border: 1px solid var(--oak-35); border-radius: 18px;
  width: 100%; max-width: 440px; padding: 1.8rem; display: flex; flex-direction: column; gap: 1.2rem;
}
.modal h2 { font-size: 22px; font-weight: 600; letter-spacing: 0.12em; text-align: center; }
.modal-line { display: flex; justify-content: space-between; font-size: 14px; color: var(--oak-60); }
.modal-line strong { color: var(--pale-oak); }
.modal-total { display: flex; justify-content: space-between; font-size: 20px; font-weight: 600; border-top: 1px solid var(--oak-20); padding-top: 0.8rem; }
.pay-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.pay-opt {
  border: 1px solid var(--oak-35); background: var(--oak-08); color: var(--pale-oak);
  padding: 12px; border-radius: 10px; cursor: pointer; font-size: 13px; letter-spacing: 0.08em; transition: background 0.15s;
}
.pay-opt:hover { background: var(--oak-20); }
.pay-opt.selected { background: var(--pale-oak); color: var(--evergreen); }
.modal-actions { display: flex; gap: 10px; }
.btn-primary {
  flex: 1; background: var(--pale-oak); color: var(--evergreen); border: none; border-radius: 10px;
  padding: 12px; font-size: 14px; font-weight: 600; letter-spacing: 0.1em; cursor: pointer;
}
.btn-primary:disabled { opacity: 0.4; cursor: not-allowed; }
.btn-ghost {
  flex: 1; background: none; color: var(--pale-oak); border: 1px solid var(--oak-35); border-radius: 10px;
  padding: 12px; font-size: 14px; letter-spacing: 0.1em; cursor: pointer;
}
.btn-ghost:hover { background: var(--oak-10); }

/* drawer carrito */
.drawer {
  position: fixed; top: 0; right: 0; height: 100%; width: 100%; max-width: 400px;
  background: var(--evergreen-soft); border-left: 1px solid var(--oak-35); z-index: 41;
  display: flex; flex-direction: column; padding: 1.5rem; gap: 1rem;
  transform: translateX(0); animation: slideIn 0.2s ease;
}
@keyframes slideIn { from { transform: translateX(100%); } to { transform: translateX(0); } }
.drawer h2 { font-size: 20px; font-weight: 600; letter-spacing: 0.12em; }
.drawer-items { flex: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; }
.drawer-item {
  display: flex; justify-content: space-between; align-items: center;
  background: var(--oak-08); border: 1px solid var(--oak-20); border-radius: 10px; padding: 10px 12px; gap: 10px;
}
.drawer-item .di-info { display: flex; flex-direction: column; gap: 2px; font-size: 13px; }
.drawer-item .di-sub { font-size: 11px; color: var(--oak-55); }
.drawer-item .di-rm { background: none; border: none; color: #e8a0a0; cursor: pointer; font-size: 18px; }
.drawer-empty { color: var(--oak-55); text-align: center; margin-top: 2rem; font-size: 14px; }

/* notificaciones */
.toast {
  position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); z-index: 60;
  background: var(--pale-oak); color: var(--evergreen); padding: 12px 22px; border-radius: 10px;
  font-size: 14px; letter-spacing: 0.05em; box-shadow: 0 6px 20px rgba(0,0,0,0.4); animation: toastIn 0.2s ease;
}
@keyframes toastIn { from { opacity: 0; transform: translate(-50%, 10px); } to { opacity: 1; transform: translate(-50%, 0); } }

/* placeholder de secciones en construcción */
.soon { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1rem; padding: 5rem 2rem; color: var(--oak-55); text-align: center; }
.soon i { font-size: 48px; opacity: 0.5; }

/* ============ RESPONSIVE ============ */
@media (max-width: 900px) { .cat-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 860px) { .prow { grid-template-columns: 1fr; } .pacts { justify-content: flex-end; } }
@media (max-width: 560px) { .cat-grid { grid-template-columns: repeat(2, 1fr); } }

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
}
